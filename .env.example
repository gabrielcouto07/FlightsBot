# Database Configuration
# For development: SQLite
DATABASE_URL=sqlite+aiosqlite:///./flight_bot.db
# For production: PostgreSQL (uncomment and configure)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/flight_bot

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Kiwi.com Tequila API Configuration
KIWI_API_KEY=your_kiwi_api_key_here
KIWI_API_BASE=https://api.tequila.kiwi.com

# WhatsApp Evolution API Configuration
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=your_evolution_api_key_here
EVOLUTION_INSTANCE_NAME=flight-bot

# WhatsApp Group JID (format: 120363xxx@g.us)
# Get this by scanning QR code in Evolution API and retrieving your instance group ID
FREE_GROUP_JID=120363xxx@g.us

# Scheduler Configuration (in minutes/hours)
SCAN_INTERVAL_MINUTES=120
FREE_DIGEST_INTERVAL_HOURS=6

# Price Deal Thresholds (in BRL - Brazilian Real)
DEFAULT_DEAL_THRESHOLD_DOMESTIC_BRL=299.0
DEFAULT_DEAL_THRESHOLD_INTL_BRL=1499.0

# Anti-spam: minimum hours between same route alert to same user
ALERT_COOLDOWN_HOURS=24

# Application Settings
APP_NAME=flight-bot
APP_VERSION=1.0.0
DEBUG=False
LOG_LEVEL=INFO

# Demo Mode
DEMO_MODE=True
WHATSAPP_ENABLED=False
FRONTEND_URL=http://localhost:3000

# Streamlit Community Cloud / admin app
# Use the public URL of your deployed FastAPI backend.
BACKEND_BASE_URL=http://localhost:8000
REQUEST_TIMEOUT_SECONDS=15
